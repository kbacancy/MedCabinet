{
  "expo": {
    "name": "MedCabinet",
    "slug": "MedCabinet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "medcabinet",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EDF4F1"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan medicine barcodes",
        "NSPhotoLibraryUsageDescription": "Used to pick medicine photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EDF4F1"
      },
      "permissions": ["CAMERA"],
      "edgeToEdgeEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MedCabinet to access your camera to scan medicine barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1D9E75"
        }
      ]
    ]
  }
}
